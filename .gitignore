# Auth — .gitignore (CONST-053 compliant: no build artefacts, caches,
# temp files, secrets, or generated reports ever committed)

# --- Build artefacts (recreatable) ---
*.exe
*.exe~
*.dll
*.so
*.dylib
*.a
*.o
*.class
*.test
/bin/
/build/
/dist/
/out/

# --- Test / coverage outputs (regeneratable via go test) ---
*.out
coverage.html
coverage.out
coverage.txt
profile.out
*.prof

# --- Caches ---
.cache/
.gocache/

# --- Temp files ---
*.tmp
*.swp
*.swo
*.orig
*.rej
*~

# --- OS / IDE personal state ---
.DS_Store
Thumbs.db
.idea/
.vscode/
.history/

# --- Sensitive-data files (CONST-042) ---
.env
.env.local
.env.*.local
.env.*
!.env.example
*.pem
*.key
*.crt
id_rsa*
id_ed25519*
.netrc
secrets/
api_keys.sh

# --- Logs ---
*.log

# --- Round-248 runner artefacts ---
/tmp/auth_round248_runner
/tmp/auth_run.log
/tmp/auth_build.log

# --- Local reports / demos (regeneratable) ---
reports/demos/

# --- Vendor (currently un-vendored) ---
# vendor/
